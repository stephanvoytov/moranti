generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Model {
  id          String    @id          // "model-001"
  name        String                 // "Birkin 13×20×8"
  slug        String    @unique      // "birkin-13x20"
  category    String                 // crossbody | tote | ...
  description String                 // Общее описание модели
  composition String?                // Основной материал
  dimensions  String?                // "13×20×8 см"
  image       String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  variants    Product[]
}

model Product {
  id                String    @id         // "mor-001"
  slug              String    @unique
  name              String
  price             Float
  originalPrice     Float
  currency          String    @default("₽")
  category          String
  description       String
  image             String
  images            String[]
  ozonImage         String?   // Фото с Ozon для админки
  ozonImages        String[]  // Все фото с Ozon для админки
  marketplaces      Json      @default("[]")
  wbArticle         BigInt?   @unique
  ozonArticle       BigInt?   @unique
  wbPrice           Float?
  wbOriginalPrice   Float?
  ozonPrice         Float?
  ozonOriginalPrice Float?
  rating            Float?
  reviewsCount      Int?
  salesCount        Int?
  imtId             Int?
  colorName         String?
  siblingIds        Int[]     @default([])
  composition       String?
  nameAutoGenerated Boolean?  @default(false)
  descAutoGenerated Boolean?  @default(false)
  archivedAt        DateTime?
  inStock           Boolean   @default(true)
  characteristics   Json?
  photoCount        Int       @default(1)
  wbCreatedAt       DateTime?
  wbUpdatedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  modelId           String?            // связь с семейством
  model             Model?     @relation(fields: [modelId], references: [id])
}

model Settings {
  id    String @id @default("singleton")
  data  Json
}
