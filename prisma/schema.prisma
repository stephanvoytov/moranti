generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id                String   @id
  slug              String   @unique
  name              String
  price             Float
  originalPrice     Float
  currency          String   @default("₽")
  category          String
  description       String
  image             String
  images            String[]
  marketplaces      Json     @default("[]")
  wbArticle         Int?     @unique
  ozonArticle       Int?
  rating            Float?
  reviewsCount      Int?
  salesCount        Int?
  imtId             Int?
  colorName         String?
  siblingIds        Int[]    @default([])
  composition       String?
  nameAutoGenerated Boolean? @default(false)
  descAutoGenerated Boolean? @default(false)
  archivedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Settings {
  id    String @id @default("singleton")
  data  Json
}
