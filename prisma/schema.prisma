generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Семейство товаров — объединяет цветовые варианты одной модели (Birkin, Balensa и т.д.).
/// Создаётся автоматически при синхронизации из WB (по imtId) или Ozon (по атрибуту 9048).
model Model {
  /// Внутренний ID: "model-wb-{imtId}" для WB-моделей, "model-ozon-{name}" для Ozon-моделей
  id          String    @id
  /// Название модели: "Birkin 13×20×8" из WB imt_name, или из атрибута Ozon 9048
  name        String
  /// URL-совместимый идентификатор: "model-wb-{imtId}" или "model-ozon-{name}"
  slug        String    @unique
  /// Категория: crossbody | na-plecho | tote | backpack | baguette | saddle
  category    String
  /// Общее описание модели (пока не заполняется, sync оставляет пустым)
  description String
  /// Основной материал модели (заполняется руками, sync не трогает)
  composition String?
  /// Габариты модели: "13×20×8 см" (заполняется руками)
  dimensions  String?
  /// Фото модели (заполняется руками)
  image       String?
  /// WB IMT ID — идентификатор группы цветов/размеров на Wildberries.
  /// Все товары с одинаковым imtId — цветовые варианты одной модели.
  /// При sync создаёт или находит Model по этому полю.
  imtId       BigInt?   @unique
  /// Порядок сортировки в каталоге (пока не используется)
  sortOrder   Int       @default(0)
  /// Когда модель архивирована (null = активна)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  /// Товары, привязанные к этой модели (цветовые варианты)
  variants    Product[]
}

/// Товар — единица каталога, сумка Moranti.
/// Соответствует одному артикулу на WB (nmId) и/или Ozon.
/// Цветовой вариант модели: несколько Product могут быть привязаны к одному Model.
model Product {
  /// Внутренний, стабильный ID: "mor-NNN" (mor-001, mor-002...).
  /// Генерируется при создании, никогда не меняется.
  id                String    @id
  /// URL-часть: "balensa-taup". Создаётся из sku через makeSlug() при создании товара.
  /// После создания не меняется (админка не пересоздаёт slug при смене sku).
  slug              String    @unique
  /// Внешний SKU — внутренний код товара у продавца, сквозной через маркетплейсы.
  /// Для WB: vendorCode из Content API (например "BalensaTaup").
  /// Для Ozon: offer_id из v3/product/list (например "BalensaTaup").
  /// Используется для матчинга товаров при синхронизации (bySku).
  /// Уникален — не может быть двух товаров с одинаковым sku.
  sku               String?   @unique
  /// Отображаемое название на сайте: "Balensa Taup" (из WB или name-generator.js).
  /// Если nameAutoGenerated = true, перезаписывается при sync.
  name              String
  /// Отображаемая цена на сайте: минимальная из wbPrice и ozonPrice (если есть).
  /// При отсутствии обоих — 0 (не показывается).
  price             Float
  /// Цена "до скидки": минимальная из wbOriginalPrice и ozonOriginalPrice.
  /// Если 0 — скидка не показывается.
  originalPrice     Float
  /// Валюта. Всегда "₽" (единственная валюта проекта).
  currency          String    @default("₽")
  /// Категория: crossbody | na-plecho | tote | backpack | baguette | saddle.
  /// Определяется через wb-categories.js по subject_id WB, либо из Ozon атрибутов.
  category          String
  /// Полное описание товара (из WB или Ozon). Если descAutoGenerated = true,
  /// перезаписывается при sync.
  description       String
  /// Главное фото для витрины. Приоритет: WB (cdn), если нет — Ozon.
  image             String
  /// Все фото товара (для галереи). Приоритет: WB (cdn), если нет — Ozon.
  images            String[]
  /// Фото с Ozon для админки (всегда Ozon-версия, отдельно от витринных фото WB).
  ozonImage         String?
  /// Все фото с Ozon для админки.
  ozonImages        String[]
  /// Ссылки на маркетплейсы для отображения на карточке товара.
  /// JSON-массив: [{ name: "Wildberries"|"Ozon", url: string, icon: string }].
  /// В БД хранится как есть (заполняется через админку или пустой массив).
  /// Через src/data/products.ts адаптер ДОгенераторует ссылки из wbArticle/ozonArticle,
  /// если они отсутствуют в хранимом массиве.
  marketplaces      Json      @default("[]")
  /// Артикул Wildberries (nmId). @unique — один товар = один nmId.
  /// Используется для генерации ссылки: /catalog/{wbArticle}/detail.aspx
  wbArticle         BigInt?   @unique
  /// Артикул Ozon (публичный SKU из sources[].sku или productSku из v3/product/list).
  /// @unique — один товар = один Ozon артикул.
  /// Используется для генерации ссылки: /product/{ozonArticle}/
  /// ⚠️ Раньше хранил product_id (внутренний ID Ozon), теперь хранит SKU.
  ozonArticle       BigInt?   @unique
  /// Цена на Wildberries (из search API). Приходит с WB синхронизацией.
  wbPrice           Float?
  /// Цена "до скидки" на Wildberries.
  wbOriginalPrice   Float?
  /// Цена на Ozon (из API, без скидки). Приходит с Ozon синхронизацией.
  ozonPrice         Float?
  /// Цена "до скидки" на Ozon.
  ozonOriginalPrice Float?
  /// Рейтинг товара. Weighted average из WB и Ozon.
  /// Показывается на сайте только если > 4.
  rating            Float?
  /// Количество отзывов (сумма с WB и Ozon).
  reviewsCount      Int?
  /// Количество продаж. ⚠️ Не заполняется — sync-all.mjs не пишет это поле.
  /// Запланировано, но заглушено. Всегда null.
  salesCount        Int?
  /// Остаток на Wildberries (из search API, stock).
  wbStock           Int?
  /// Остаток на Ozon (сумма (present - reserved) по всем складам FBO/FBS).
  ozonStock         Int?
  /// Название цвета (из WB или Ozon): "Тауп", "Молочный" и т.д.
  /// Используется для отображения на карточке товара.
  colorName         String?
  /// Состав материала: "натуральная кожа 100%", "замша" и т.д.
  /// Используется для генерации colorLabel на витрине.
  composition       String?
  /// Флаг: название сгенерировано автоматически (name-generator.js).
  /// Если false — sync не перезаписывает название (ручная правка).
  /// При создании товара всегда ставится true (sync-all.mjs: line 992, 1408).
  /// Prisma default(false) — заглушка; код всегда передаёт явное значение.
  nameAutoGenerated Boolean?  @default(false)
  /// Флаг: описание сгенерировано автоматически.
  /// Если false — sync не перезаписывает описание (ручная правка).
  /// При создании товара всегда ставится true.
  descAutoGenerated Boolean?  @default(false)
  /// Когда товар архивирован. Null = активен.
  /// Ставится sync-all.mjs, если товара нет ни на одном маркетплейсе.
  archivedAt        DateTime?
  /// Наличие на сайте. true — показывается в каталоге.
  /// Для новых товаров: ставится при создании (по стоку WB search API или Ozon).
  /// Для существующих: обновляется только archiveGoneProducts() — если товар
  /// пропал со всех маркетплейсов → archivedAt + inStock=false.
  /// ⚠️ Если товар есть на WB, но закончился сток — inStock НЕ меняется
  /// (mergeProductSources не трогает inStock).
  inStock           Boolean   @default(true)
  /// Характеристики товара: JSON-массив [{ group_name, options: [{ name, value }] }].
  /// Из WB card.json (subject_name, brand_name, color, material и т.д.) и Ozon атрибутов.
  /// Пример: [{ group_name: "Wildberries", options: [{ name: "Бренд", value: "Moranti" }] }]
  characteristics   Json?
  /// Количество фото. Используется для CDN URL генерации (WB).
  photoCount        Int       @default(1)
  /// Когда товар создан на Wildberries (из card.json).
  wbCreatedAt       DateTime?
  /// Когда товар обновлён на Wildberries.
  wbUpdatedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  /// Привязка к семейству (Model). Один Model = несколько Product (цветовые варианты).
  modelId           String?
  model             Model?     @relation(fields: [modelId], references: [id])
}

/// Настройки сайта: hero-секция, SEO, соцсети, API-ключи и т.д.
/// Singleton-запись — всегда одна, id="singleton".
model Settings {
  id    String @id @default("singleton")
  /// JSON-объект со всеми настройками. Читается через src/lib/settings.ts.
  /// Структура: { heroTitle, heroSubtitle, seoTitle, seoDescription,
  ///   socialLinks, apiKeys, ... }
  data  Json
}

/// Запись синхронизации с маркетплейсом (WB или Ozon).
/// Хранит результат запуска sync-all.mjs: статус, статистику, лог.
/// Вместо data/sync-history.json — теперь в БД.
model SyncRun {
  id        String   @id @default(cuid())
  /// Платформа: "wb" или "ozon"
  platform  String
  /// Когда запущена синхронизация
  timestamp DateTime @default(now())
  /// Длительность в миллисекундах
  duration  Int
  /// Успешно ли завершилась
  success   Boolean
  /// Текст ошибки (если была)
  error     String?
  /// Сколько товаров добавлено
  added     Int      @default(0)
  /// Сколько товаров обновлено
  updated   Int      @default(0)
  /// Сколько товаров архивировано
  archived  Int      @default(0)
  /// Сколько товаров пропущено
  skipped   Int      @default(0)
  /// Сколько ошибок
  errors    Int      @default(0)
  /// Полный вывод sync-скрипта
  log       String   @default("")

  createdAt DateTime @default(now())

  @@index([platform, timestamp])
}
